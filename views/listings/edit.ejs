<%- layout("./layouts/boilerplate"); %>
    <div class="row mt-3">
        <div class="col-8 offset-2">

            <h1>Create new list</h1>

            <form novalidate class="needs-validation" method="post" required
                action="/listings/<%= listing._id %>?_method=PUT">

                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" value="<%= listing.title  %>" name="listing[title]" class="form-control"
                        id="title" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">More example invalid feedback text</div>

                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="listing[description]" id="description" class="form-control"
                        required> <%= listing.description %></textarea>
                    <div class="invalid-feedback">More example invalid feedback text</div>
                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Image URL</label>
                    <input type="text" value="<%= listing.image.url %>" name="listing[image][url]" class="form-control"
                        id="image" required>
                    
                    <div class="invalid-feedback">
                        Please select a valid state.
                    </div>
                </div>

                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input type="number" value="<%= listing.price %>" name="listing[price]" class="form-control"
                            id="price" required>
                     
                        <div class="invalid-feedback">
                            Please select a valid state.
                        </div>
                    </div>

                    <div class="mb-3 col-md-8">
                        <label for="location" class="form-label">location</label>
                        <input type="text" value="<%= listing.location %>" name="listing[location]" class="form-control"
                            id="location" required>
                    
                        <div class="invalid-feedback">
                            Please select a valid state.
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="country" class="form-label">country</label>
                    <input type="text" value="<%= listing.country %>" name="listing[country]" class="form-control"
                        id="country" required>
                
                    <div class="invalid-feedback">
                        Please select a valid state.
                    </div>
                </div>
                <button class="btn btn-danger">Edit</button>
            </form>


        </div>
    </div>