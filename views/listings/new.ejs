<%- layout("./layouts/boilerplate"); %>

    <div class="row mt-3">
        <div class="col-8 offset-2">
            <br><br>
            <h1>Create new list</h1>

            <form action="/listings" method="post" novalidate class="needs-validation" required>

                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" placeholder="(eg.Heaven on earth)" name="listing[title]" class="form-control"
                        id="title" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">
                        Please select title
                    </div>

                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="listing[description]" id="description" placeholder="(eg.Heavenly place to visite)"
                        class="form-control" required></textarea>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">
                        Please enter valid descriptiom
                    </div>

                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Image URL</label>
                    <input type="text" placeholder="(eg.https://image.png)" name="listing[image][url]" required
                        class="form-control" id="image">
                    <div class="invalid-feedback">
                        Please enter valid url of image 
                    </div>

                </div>

                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input placeholder="1111" required name="listing[price]" class="form-control"
                            id="price">
                        <div class="invalid-feedback">
                           Please enter valid price
                        </div>

                    </div>

                    <div class="mb-3 col-md-8">
                        <label for="location" class="form-label">location</label>
                        <input type="text" placeholder="(eg.Mumbai)" required name="listing[location]"
                            class="form-control" id="location">
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                             Please enter valid location
                        </div>

                    </div>
                </div>
                <div class="mb-3">
                    <label for="  Please enter valid price" class="form-label">country</label>
                    <input type="text" placeholder="(eg.India)" required name="listing[country]" class="form-control"
                        id="country">
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">
                          Please enter valid country
                    </div>

                </div>
                <button type="submit" class="btn btn-danger add-btn">submit</button>
                <br>
            </form>



        </div>
    </div>